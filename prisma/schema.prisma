// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum PublicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmailStatus {
  SENT
  FAILED
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  name         String    @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  role         UserRole  @default(VIEWER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  passwordResetTokens PasswordResetToken[]
  uploadedPdfs Pdf[]

  @@map("users")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(512)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Magazine {
  id                     Int       @id @default(autoincrement())
  title                  String    @db.VarChar(255)
  description            String    @db.Text
  image                  String    @db.VarChar(255)
  category               String    @db.VarChar(100)
  pdfUrl                 String?   @db.VarChar(500)
  issn                   String?   @db.VarChar(32)
  impactFactor           Decimal?  @db.Decimal(6, 3)
  currentVersion         String?   @db.VarChar(50)
  nextVersionRelease     DateTime?
  publicationPreference  String?   @db.Text
  versionMessage         String?   @db.Text
  certification          String?   @db.Text
  advisorsApproved       Boolean   @default(false)
  versionCount           Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  versions               MagazineVersion[]
  advisors               MagazineAdvisor[]
  approvedAdvisors       MagazineApprovedAdvisor[]

  @@map("magazines")
}

model MagazineApprovedAdvisor {
  id               Int            @id @default(autoincrement())
  magazineId       Int
  advisoryMemberId Int
  createdAt        DateTime       @default(now())
  magazine         Magazine       @relation(fields: [magazineId], references: [id], onDelete: Cascade)
  advisoryMember   AdvisoryMember @relation(fields: [advisoryMemberId], references: [id], onDelete: Cascade)

  @@unique([magazineId, advisoryMemberId])
  @@index([magazineId])
  @@index([advisoryMemberId])
  @@map("magazine_approved_advisors")
}

model MagazineAdvisor {
  id          Int      @id @default(autoincrement())
  magazineId Int
  photoUrl   String   @db.VarChar(500)
  name       String   @db.VarChar(255)
  jobTitle   String   @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  magazine   Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@index([magazineId])
  @@map("magazine_advisors")
}

model MagazineVersion {
  id          Int      @id @default(autoincrement())
  magazineId  Int
  version     String   @db.VarChar(50)
  title       String   @db.VarChar(255)
  releaseDate DateTime
  notes       String?  @db.Text
  pageCount   Int?
  pdfUrl      String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  magazine    Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@index([magazineId])
  @@map("magazine_versions")
}

model PublicationRequest {
  id             Int               @id @default(autoincrement())
  authorName     String            @db.VarChar(255)
  authorEmail    String            @db.VarChar(255)
  title          String            @db.VarChar(255)
  abstract       String            @db.Text
  field          String?           @db.VarChar(255)
  status         PublicationStatus @default(PENDING)
  reviewNotes    String?           @db.Text
  reviewedById   Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@map("publication_requests")
}

model EmailLog {
  id        Int         @id @default(autoincrement())
  to        String      @db.VarChar(255)
  subject   String      @db.VarChar(255)
  body      String      @db.Text
  status    EmailStatus
  error     String?     @db.Text
  sentById  Int?
  sentAt    DateTime    @default(now())

  @@index([sentAt])
  @@map("email_logs")
}

model BlogPost {
  id      Int     @id @default(autoincrement())
  title   String  @db.VarChar(255)
  summary String  @db.Text
  date    String  @db.VarChar(50)
  author  String  @db.VarChar(255)
  image   String? @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blogs")
}

model Conference {
  id        Int     @id @default(autoincrement())
  title     String  @db.VarChar(255)
  description String  @db.Text
  date      String  @db.VarChar(50)
  location  String  @db.VarChar(255)
  image     String? @db.VarChar(255)
  attendees String? @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("conferences")
}

model AdvisoryMember {
  id    Int     @id @default(autoincrement())
  name  String  @db.VarChar(255)
  title String  @db.VarChar(255)
  image String? @db.VarChar(255)
  bio   String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  approvedForMagazines MagazineApprovedAdvisor[]

  @@map("advisory_committee_members")
}

model Field {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fields")
}

model Pdf {
  id        Int       @id @default(autoincrement())
  filename  String    @db.VarChar(255)
  filepath  String    @db.VarChar(500)
  size      Int
  uploaded_at DateTime @default(now())
  status    String    @db.VarChar(50) @default("active")
  mimeType  String?   @db.VarChar(100)
  uploadedById Int?
  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@map("pdfs")
}

model MagazineTraffic {
  id          Int      @id @default(autoincrement())
  magazineId  Int
  views       Int      @default(0)
  downloads   Int      @default(0)
  shares      Int      @default(0)
  date        DateTime @default(now())
  userAgent   String?  @db.Text
  ipAddress   String?  @db.VarChar(45)

  @@map("magazine_traffic")
  @@index([magazineId])
}
