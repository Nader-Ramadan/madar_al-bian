# --- MySQL (Hostinger production) ---------------------------------------------
# From hPanel: Websites → Manage → Databases → MySQL — copy Host, Username,
# Password, Database name, and Port (hPanel may show 3306 or a custom port).
# If the app runs on a different server than the DB, enable Remote MySQL and
# allow the app server's IP.
#
# Runtime needs EITHER a full DATABASE_URL OR all of: DB_HOST, DB_USER,
# DB_PASSWORD, DB_NAME (DB_PORT optional, default 3306). If both are set,
# DATABASE_URL wins. Special characters in passwords: use DB_* vars (encoded
# automatically) or URL-encode the password inside DATABASE_URL only.
#
# Set these only on Hostinger: hPanel → Node.js app → Environment variables,
# and/or .env.production in the application root on the server (same folder as
# package.json). Do not use .env.local for production database credentials.
#
# After first deploy (SSH or panel terminal, same env as the app):
#   npx prisma migrate deploy
#   npm run db:seed
# Verify: https://your-domain/api/magazines?limit=5

DB_HOST=srv443.hstgr.io
DB_USER=u554314341_root
DB_PASSWORD=0U+@POL6^n
DB_NAME=u554314341_magazines
DB_PORT=3306

# Prisma schema reads env("DATABASE_URL"); the app also builds a URL from DB_* if unset.
DATABASE_URL=mysql://u554314341_root:0U+@POL6^n:3306/u554314341_magazines

JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth (admin login). Redirect URI must match Google Cloud Console exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace_with_strong_password
BOOTSTRAP_ADMIN_NAME=Admin User

S3_REGION=us-east-1
S3_BUCKET=your_bucket
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_PUBLIC_BASE_URL=https://cdn.example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Madar Al-Bian <noreply@example.com>
