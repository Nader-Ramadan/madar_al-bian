# --- MySQL (Hostinger only) ---------------------------------------------------
# Provision MySQL in Hostinger: hPanel → Websites → Manage → Databases → MySQL.
# Copy Host (often *.hstgr.io or srvXXXX.hstgr.io — replace XXXX with your panel
# value), Username, Password, Database name, and Port from that screen.
#
# hPanel may show port 3306 or a custom port — use the same value in DB_PORT
# and inside DATABASE_URL below.
#
# Set production database variables only on Hostinger: Node.js app → Environment
# variables, and/or .env.production on the server (next to package.json). Do not
# put production DB credentials in .env.local on your laptop.
#
# If the Node app and MySQL are not on the same internal network, enable Remote
# MySQL in hPanel and allow the app server’s IP.
#
# Runtime: set EITHER DATABASE_URL (mysql://…) OR all of DB_HOST, DB_USER,
# DB_PASSWORD, DB_NAME (DB_PORT optional; default 3306). If both are set,
# DATABASE_URL wins per lib/database-url.ts (wrong DATABASE_URL → P1000 auth errors).
#
# Passwords with @ : / # ? % + | ; etc.: put the real value in hPanel or .env /
# .env.production only — never in this file. Prefer DB_* vars: lib/database-url.ts
# encodes DB_PASSWORD when building DATABASE_URL. For DATABASE_URL alone, percent-
# encode every special character in the password.
#
# If you keep ONLY DATABASE_URL in hPanel: the password between mysql://USER: and @HOST
# must match MySQL exactly (encoded). Wrong URL password → P1000. Run: npm run check:db-env
# on the server for URL-shape hints; prefer DB_* only to avoid manual encoding errors.
#
# Use the same database for: npx prisma migrate deploy, npm run db:seed, and the
# running app (SSH/panel terminal must see the same env as the Node process).
# Verify after deploy: https://your-domain/api/magazines?limit=5

DB_HOST=srv443.hstgr.io
DB_PORT=3306
DB_USER=u554314341_root
DB_PASSWORD=Mb7zD7%3Ba
DB_NAME=u554314341_magazines

# Prisma schema uses env("DATABASE_URL"); placeholders only (match DB_* above).
DATABASE_URL=mysql://u554314341_root:Mb7zD7%3Ba@srv443.hstgr.io:3306/u554314341_magazines

JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth (admin login). Redirect URI must match Google Cloud Console exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace_with_strong_password
BOOTSTRAP_ADMIN_NAME=Admin User

S3_REGION=us-east-1
S3_BUCKET=your_bucket
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_PUBLIC_BASE_URL=https://cdn.example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Madar Al-Bian <noreply@example.com>
